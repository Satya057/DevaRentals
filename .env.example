# --- Option A: Gmail (good for info.devarentals@gmail.com) ---
# 1) Turn on 2-Step Verification on the Google account (complete the phone prompt when signing in).
# 2) Google Account → Security → App passwords → create one for "Mail".
# 3) Paste that 16-character password below (not your normal Gmail password).

GMAIL_USER=info.devarentals@gmail.com
GMAIL_APP_PASSWORD=

# Optional. Who receives the inquiry. If empty, mail goes to GMAIL_USER (same inbox).
LANDLORD_INQUIRY_TO_EMAIL=info.devarentals@gmail.com

# Optional display name in the "From" field when using Gmail
EMAIL_FROM_NAME=Deva Rentals

# --- Option B: Resend (if you prefer not to use Gmail SMTP) ---
# RESEND_API_KEY=
# LANDLORD_INQUIRY_TO_EMAIL=info.devarentals@gmail.com
# EMAIL_FROM=Deva Rentals <hello@your-verified-domain.com>

# --- Schedule Viewing form (separate Gmail recommended) ---
# SCHEDULE_GMAIL_USER=showings.devarentals@gmail.com
# SCHEDULE_GMAIL_APP_PASSWORD=
# SCHEDULE_VIEWING_TO_EMAIL=showings.devarentals@gmail.com
# SCHEDULE_EMAIL_FROM_NAME=Deva Rentals

# Optional: rental applications default to SCHEDULE_VIEWING_TO_EMAIL (showings inbox)
# RENTAL_APPLICATION_TO_EMAIL=showings.devarentals@gmail.com

# --- Service Request (maintenance) form ---
# SERVICE_REQUEST_GMAIL_USER=service.devarentals@gmail.com
# SERVICE_REQUEST_GMAIL_APP_PASSWORD=
# Optional. Defaults to SERVICE_REQUEST_GMAIL_USER if unset.
# SERVICE_REQUEST_TO_EMAIL=service.devarentals@gmail.com
# SERVICE_REQUEST_EMAIL_FROM_NAME=Deva Rentals

# --- Hero background video (optional) ---
# Bump after replacing public/video/Hero.mp4 so browsers fetch a fresh copy (e.g. 3, 4, …).
# NEXT_PUBLIC_HERO_VIDEO_V=2
# Office PCs with “Reduce motion” on: set to 1 to still autoplay hero video (optional).
# NEXT_PUBLIC_HERO_FORCE_VIDEO=1
